# Proveedor del modelo: openai | azure_openai
LLM_PROVIDER=

# Modelo principal usado por los agentes especializados
OPENAI_MODEL=

# Modelo más liviano para clasificación (opcional)
ROUTER_MODEL=

# API key de OpenAI
OPENAI_API_KEY=

# Azure OpenAI (solo si LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Firecrawl para búsquedas web (tool search_web)
FIRECRAWL_API_KEY=
FIRECRAWL_API_BASE_URL=

# Endpoint HTTP que expone consulta de base de conocimiento vía MCP
MCP_KB_ENDPOINT=

# Token opcional para autenticar contra el endpoint MCP KB
MCP_KB_TOKEN=

# Carpeta donde se guardan PDFs generados por el agente
PDF_OUTPUT_DIR=
